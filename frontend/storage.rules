rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Assignment submissions: enforce student can only write to their own UID folder.
    match /assignment_submissions/{assignmentId}/{studentUid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == studentUid;
    }

    // Quiz question images: faculty uploads images and stores downloadURL in RTDB.
    // Keep writes limited to the uploader's UID subtree.
    match /quiz_question_images/{uploaderUid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uploaderUid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Fallback: block everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
